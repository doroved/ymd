{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "YandexMusicDownloader",
  "short_name": "YMDownloader",
  "description": "Скачивайте любые треки с Яндекс.Музыка в высоком качестве. Просто и удобно!",
  "version": "0.1.0",
  "minimum_chrome_version": "109",
  "incognito": "not_allowed",

  "background": {
    "service_worker": "sw.js"
  },

  "permissions": ["storage", "downloads"],

  "host_permissions": [
    "*://api.music.yandex.ru/*",
    "*://api.music.yandex.by/*",
    "*://api.music.yandex.kz/*",
    "*://api.music.yandex.uz/*",
    "*://api.music.yandex.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://music.yandex.ru/*",
        "*://music.yandex.by/*",
        "*://music.yandex.kz/*",
        "*://music.yandex.uz/*",
        "*://music.yandex.com/*"
      ],
      "css": ["content/content.css"],
      "js": ["content/tag.js", "content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_title": "YandexMusicDownloader"
  },

  "options_page": "options/options.html",
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
