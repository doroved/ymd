{
  "manifest_version": 3,
  "name": "Yandex Music Downloader",
  "short_name": "YMDownloader",
  "description": "Скачиваем Я.Музыку быстро, бесплатно и в высоком качестве!",
  "version": "0.2.1",
  "homepage_url": "https://github.com/doroved/ymd",
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "*://api.music.yandex.ru/*",
    "*://api.music.yandex.by/*",
    "*://api.music.yandex.kz/*",
    "*://api.music.yandex.uz/*",
    "*://api.music.yandex.com/*",
    "*://*.strm.yandex.net/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ymd@doroved.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["src/sw.js"]
  },
  "action": {
    "default_title": "Yandex Music Downloader"
  },
  "icons": {
    "128": "src/icons/128.png",
    "16": "src/icons/16.png",
    "32": "src/icons/32.png",
    "48": "src/icons/48.png"
  },
  "content_scripts": [
    {
      "all_frames": true,
      "css": ["src/content.css"],
      "js": ["src/tag.js", "src/content.js"],
      "matches": [
        "*://music.yandex.ru/*",
        "*://music.yandex.by/*",
        "*://music.yandex.kz/*",
        "*://music.yandex.uz/*",
        "*://music.yandex.com/*"
      ],
      "run_at": "document_start"
    }
  ],
  "options_page": "src/options/options.html",
  "options_ui": {
    "open_in_tab": true,
    "page": "src/options/options.html"
  },
  "incognito": "not_allowed"
}
